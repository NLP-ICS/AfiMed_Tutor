# Choose one provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required if LLM_PROVIDER=openai OR for embeddings)
OPENAI_API_KEY=sk-...

# Embedding provider: "openai" (text-embedding-3-small) or "voyage"
EMBEDDING_PROVIDER=openai

# Voyage AI key (required if EMBEDDING_PROVIDER=voyage)
VOYAGE_API_KEY=pa-...

# Retriever backend: "dense" or "sparse"
RETRIEVER_BACKEND=dense

# Top-k chunks to retrieve per query
RETRIEVER_TOP_K=5

# Cosine similarity threshold (drop chunks below this score)
RETRIEVER_THRESHOLD=0.30

# Related questions: "semantic" or "keyword"
RELATED_Q_METHOD=semantic

# Model names (defaults shown)
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
